{
  "name": "rn-managed-template",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild --clean",
    "android:clean": "npm run prebuild && expo run:android",
    "ios:clean": "npm run prebuild && expo run:ios",
    "lint": "eslint ./src/**/*.{js,ts,jsx,tsx}",
    "lint:fix": "eslint ./src/**/*.{js,ts,jsx,tsx} --fix",
    "compile:apk": "npm run prebuild && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.7.9",
    "expo": "~52.0.18",
    "expo-font": "~13.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.6",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-edge-to-edge": "^1.1.3",
    "react-native-mmkv": "^3.1.0",
    "react-native-nitro-modules": "^0.18.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-unistyles": "^3.0.0-beta.2",
    "react-redux": "^9.2.0",
    "expo-image": "~2.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "typescript": "^5.3.3"
  },
  "private": true
}
